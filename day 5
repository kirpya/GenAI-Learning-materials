from sentence_transformers import SentenceTransformer
from sklearn.metrics.pairwise import cosine_similarity

documents = [
    "Python is a popular programming language for AI and data science.",
    "Deep learning models require large amounts of training data.",
    "The stock market saw significant gains today.",
    "Neural networks are inspired by the human brain.",
    "Investors are worried about inflation and interest rates.",
    "Machine learning is a subset of artificial intelligence."
]

model = SentenceTransformer('all-MiniLM-L6-v2')
doc_embeddings = model.encode(documents)

def search(query, top_n=3):
    query_embedding = model.encode([query])
    similarities = cosine_similarity(query_embedding, doc_embeddings).flatten()
    ranked_indices = similarities.argsort()[::-1][:top_n]

    print(f"\nQuery: {query}")
    for idx in ranked_indices:
        print(f"  Score: {similarities[idx]:.3f} | {documents[idx]}")

search("AI and neural networks")
search("finance and economy")

from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity

documents = [
    "Python is a popular programming language for AI and data science.",
    "Deep learning models require large amounts of training data.",
    "The stock market saw significant gains today.",
    "Neural networks are inspired by the human brain.",
    "Investors are worried about inflation and interest rates.",
    "Machine learning is a subset of artificial intelligence."
]

vectorizer = TfidfVectorizer()
doc_vectors = vectorizer.fit_transform(documents)   # this acts like our tiny "vector database"

def search(query, top_n=3):
    query_vector = vectorizer.transform([query])
    similarities = cosine_similarity(query_vector, doc_vectors).flatten()
    ranked_indices = similarities.argsort()[::-1][:top_n]

    print(f"\nQuery: {query}")
    for idx in ranked_indices:
        print(f"  Score: {similarities[idx]:.3f} | {documents[idx]}")

search("AI and neural networks")
search("finance and economy")
