def add_note():
    note=input("Enter your note: ")
    with open ("notes.txt","a") as file:
        file.write(note + "\n")
        print("Note saved successfully.")


def view_notes():
    try:
        with open("notes.txt", "r") as file:
            content = file.read()
            if content:
                print("Your notes:")
                print(content)
            else:
                print("No note found.")
    
    except FileNotFoundError:
        print("NO note found.")


def main():
    while True:
        print("1.Add Note")
        print("2.View Notes")
        print("3.Exit")
        choice = input("Enter your choice:")

        if choice == "1":
          add_note()
        elif choice == "2":
          view_notes()
        elif choice == "3":
          print("Exiting the program.")
          break    
        else:
           print("Invalid choice. Please try again.")

main()   
